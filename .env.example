# Supabase (hämtas från: supabase.com/dashboard/project/ozmpxldmgivggbmwhtjt/settings/api)
SUPABASE_URL=https://ozmpxldmgivggbmwhtjt.supabase.co
SUPABASE_ANON_KEY=

# Stripe (hämtas från: dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_STARTER=price_...   # 499 kr/mån – 1 seat
STRIPE_PRICE_TEAM=price_...      # 1 990 kr/mån – 5 seats
STRIPE_PRICE_GROWTH=price_...    # 3 990 kr/mån – 15 seats
STRIPE_WEBHOOK_SECRET=whsec_...

# Mapbox — primär bildkälla för satellitbilder (200 000 gratis/mån)
# Hämta token: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# Google Maps (Geocoding API + fallback satellit om Mapbox saknas)
GOOGLE_API_KEY=

# Lantmäteriet öppna geodatatjänster (gratis, CC-BY)
# Hämta nyckel: https://apimanager.lantmateriet.se/devportal/apis
LANTMATERIET_KEY=

# Anthropic Claude (AI-detektion av solpaneler i scanner.py)
# Hämta nyckel: https://console.anthropic.com/settings/keys
#
# VIKTIGT: nyckeln läggs under SOLAR_SCOUT_ANTHROPIC_KEY (inte ANTHROPIC_API_KEY).
# Skälet: Claude Code CLI letar specifikt efter env-varianten ANTHROPIC_API_KEY
# och växlar då sin egen billing från OAuth-prenumeration till API-credits utan
# varning. Genom att prefixa namnet undviker vi att en lokal `source .env` råkar
# kosta pengar nästa gång du startar `claude` i projektet.
# app.py kollar SOLAR_SCOUT_ANTHROPIC_KEY först, faller tillbaka på
# ANTHROPIC_API_KEY för bakåtkompatibilitet med existerande Streamlit-secrets.
SOLAR_SCOUT_ANTHROPIC_KEY=

# Din Railway-URL (uppdatera efter deploy)
APP_URL=https://din-app.railway.app
